{
  "manifest_version": 2,
  "name": "Supertonic TTS",
  "version": "1.0",
  "description": "Text-to-speech powered by Supertonic 2 CoreML",

  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png",
      "96": "icon96.png"
    },
    "default_title": "Supertonic TTS"
  },

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "activeTab",
    "tabs"
  ]
}
